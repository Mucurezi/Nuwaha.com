# Ignore sensitive configuration files
config/database.php
config/notification.php

# Ignore log files
logs/*.log
logs/*.txt
!logs/.gitkeep

# Ignore temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db
desktop.ini

# Ignore IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore vendor/dependencies (if using Composer)
vendor/

# Ignore uploaded files (if you have an uploads folder)
uploads/*
!uploads/.gitkeep

# Ignore debug files
api/*_debug.php
admin/create_admin.php
admin/reset_password.php

# Ignore backup files
*.bak
*.backup
*.sql.gz
